{
  "openapi": "3.1.1",
  "info": {
    "title": "SovereignID - Academy API",
    "description": "Servicio academico de la plataforma SovereignID. Gestiona instituciones, carreras, estudiantes e invitaciones para vincular wallets MetaMask existentes. Los errores de negocio se devuelven como RFC 7807 Problem Details con un codigo estable en la extension `error`.",
    "contact": {
      "name": "SovereignID",
      "url": "https://github.com/nasotop/SovereignID"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:5195/"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Comprueba que el servicio estÃ¡ operativo (liveness check).",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { }
            }
          }
        }
      }
    },
    "/academy/invitations/accept": {
      "post": {
        "tags": [
          "InstitutionInvitations"
        ],
        "summary": "Acepta una invitacion y guarda la wallet MetaMask existente del usuario institucional.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptInstitutionInvitationRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptInstitutionInvitationRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptInstitutionInvitationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InstitutionInvitationAccepted"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/academy/institutions": {
      "post": {
        "tags": [
          "Institutions"
        ],
        "summary": "Crea una institucion y envia una invitacion para vincular una wallet MetaMask existente.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInstitutionRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInstitutionRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInstitutionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InstitutionCreated"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/academy/institutions/{institutionId}": {
      "get": {
        "tags": [
          "Institutions"
        ],
        "summary": "Consulta una institucion por identificador.",
        "parameters": [
          {
            "name": "institutionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InstitutionSummary"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/academy/institutions/{institutionId}/careers": {
      "post": {
        "tags": [
          "Institutions"
        ],
        "summary": "Crea una carrera dentro de una institucion.",
        "parameters": [
          {
            "name": "institutionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCareerRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCareerRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCareerRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CareerSummary"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/academy/institutions/{institutionId}/students": {
      "post": {
        "tags": [
          "Institutions"
        ],
        "summary": "Crea un estudiante y, si se informa, vincula su wallet MetaMask existente como primaria.",
        "parameters": [
          {
            "name": "institutionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateStudentRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateStudentRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateStudentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StudentSummary"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/academy/institutions/{institutionId}/invitations": {
      "post": {
        "tags": [
          "Institutions"
        ],
        "summary": "Crea una invitacion para que un usuario de institucion vincule una wallet MetaMask existente.",
        "parameters": [
          {
            "name": "institutionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInstitutionInvitationRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInstitutionInvitationRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInstitutionInvitationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InstitutionInvitationCreated"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AcceptInstitutionInvitationRequest": {
        "required": [
          "token",
          "walletAddress",
          "displayName"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "walletAddress": {
            "type": "string"
          },
          "displayName": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CareerSummary": {
        "required": [
          "id",
          "institutionId",
          "code",
          "name",
          "isActive",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "institutionId": {
            "type": "string",
            "format": "uuid"
          },
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateCareerRequest": {
        "required": [
          "code",
          "name"
        ],
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "CreateInstitutionInvitationRequest": {
        "required": [
          "email"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "default": "issuer"
          },
          "createdByUserId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          }
        }
      },
      "CreateInstitutionRequest": {
        "required": [
          "code",
          "legalName",
          "displayName",
          "contactEmail"
        ],
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "legalName": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "contactEmail": {
            "type": "string"
          },
          "countryCode": {
            "type": "string",
            "default": "CL"
          },
          "websiteUrl": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateStudentRequest": {
        "required": [
          "externalReference",
          "enrollmentYear",
          "walletAddress"
        ],
        "type": "object",
        "properties": {
          "externalReference": {
            "type": [
              "null",
              "string"
            ]
          },
          "enrollmentYear": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "walletAddress": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "InstitutionCreated": {
        "required": [
          "institution",
          "invitation"
        ],
        "type": "object",
        "properties": {
          "institution": {
            "$ref": "#/components/schemas/InstitutionSummary"
          },
          "invitation": {
            "$ref": "#/components/schemas/InstitutionInvitationCreated"
          }
        }
      },
      "InstitutionInvitationAccepted": {
        "required": [
          "institutionId",
          "userId",
          "walletAddress",
          "did",
          "role"
        ],
        "type": "object",
        "properties": {
          "institutionId": {
            "type": "string",
            "format": "uuid"
          },
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "walletAddress": {
            "type": "string"
          },
          "did": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "InstitutionInvitationCreated": {
        "required": [
          "id",
          "institutionId",
          "email",
          "role",
          "invitationUrl",
          "expiresAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "institutionId": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "invitationUrl": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "InstitutionSummary": {
        "required": [
          "id",
          "code",
          "legalName",
          "displayName",
          "did",
          "issuerWalletAddress",
          "countryCode",
          "websiteUrl",
          "isActive",
          "registeredAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "code": {
            "type": "string"
          },
          "legalName": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "did": {
            "type": [
              "null",
              "string"
            ]
          },
          "issuerWalletAddress": {
            "type": [
              "null",
              "string"
            ]
          },
          "countryCode": {
            "type": "string"
          },
          "websiteUrl": {
            "type": [
              "null",
              "string"
            ]
          },
          "isActive": {
            "type": "boolean"
          },
          "registeredAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "StudentSummary": {
        "required": [
          "id",
          "institutionId",
          "externalReference",
          "enrollmentYear",
          "primaryWalletId",
          "primaryWalletAddress",
          "primaryWalletDid",
          "isActive",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "institutionId": {
            "type": "string",
            "format": "uuid"
          },
          "externalReference": {
            "type": [
              "null",
              "string"
            ]
          },
          "enrollmentYear": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "primaryWalletId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "primaryWalletAddress": {
            "type": [
              "null",
              "string"
            ]
          },
          "primaryWalletDid": {
            "type": [
              "null",
              "string"
            ]
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Health"
    },
    {
      "name": "InstitutionInvitations"
    },
    {
      "name": "Institutions"
    }
  ]
}