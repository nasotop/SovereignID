{
  "openapi": "3.1.1",
  "info": {
    "title": "SovereignID · Auth API",
    "description": "Autenticación Sign-In with Ethereum (EIP-4361) para Ethereum Sepolia (chain ID 11155111). Emite un reto de un solo uso (`GET /auth/nonce`) y verifica un mensaje SIWE firmado para entregar un JWT de sesión (`POST /auth/verify`). Los errores de negocio se devuelven como RFC 7807 Problem Details con un código estable en la extensión `error` (p. ej. `nonce_expired`, `signature_mismatch`).",
    "contact": {
      "name": "SovereignID",
      "url": "https://github.com/nasotop/SovereignID"
    },
    "version": "v1"
  },
  "paths": {
    "/auth/nonce": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Emite un auth challenge (nonce de un solo uso, TTL 600 s).",
        "description": "El nonce devuelto debe incluirse en el mensaje SIWE que se firma y envía a `POST /auth/verify`.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NonceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/verify": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Verifica un mensaje SIWE firmado y, si es válido, emite un JWT de sesión (TTL 24 h).",
        "description": "Errores de negocio (RFC 7807 Problem Details, extensión `error`): `siwe_parse_failed` y `unsupported_chain` (400); `nonce_unknown`, `nonce_expired`, `nonce_consumed` y `signature_mismatch` (401).",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "NonceResponse": {
        "required": [
          "nonce",
          "expiresAt"
        ],
        "type": "object",
        "properties": {
          "nonce": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "VerifyRequest": {
        "required": [
          "message",
          "signature"
        ],
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "signature": {
            "type": "string"
          }
        }
      },
      "VerifyResponse": {
        "required": [
          "jwt",
          "address",
          "expiresAt"
        ],
        "type": "object",
        "properties": {
          "jwt": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    }
  ]
}
