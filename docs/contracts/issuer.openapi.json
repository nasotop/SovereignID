{
  "openapi": "3.1.1",
  "info": {
    "title": "SovereignID - Issuer API",
    "description": "Servicio emisor de Verifiable Credentials de la plataforma SovereignID. Vincula la wallet/DID emisor de una institucion y titulos emitidos a estudiantes usando la wallet primaria activa del estudiante. Los errores de negocio se devuelven como RFC 7807 Problem Details con un codigo estable en la extension `error`.",
    "contact": {
      "name": "SovereignID",
      "url": "https://github.com/nasotop/SovereignID"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:5197/"
    }
  ],
  "paths": {
    "/issuer/credentials/{credentialId}": {
      "get": {
        "tags": [
          "Credentials"
        ],
        "summary": "Devuelve el detalle de una credencial autenticada si pertenece al titular del JWT.",
        "parameters": [
          {
            "name": "credentialId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HolderCredentialDetail"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Comprueba que el servicio está operativo (liveness check).",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { }
            }
          }
        }
      }
    },
    "/issuer/institutions/{institutionId}/wallet": {
      "post": {
        "tags": [
          "InstitutionIssuerWallet"
        ],
        "summary": "Vincula la wallet/DID emisor de una institucion existente.",
