# ============================================================================
# SovereignID Docker Compose Environment Variables
# ============================================================================
# Copiar este archivo a .env y ajustar valores según tu entorno
# cp .env.example .env
# ============================================================================

# ============================================================================
# Auth API (.NET 10) Configuration
# ============================================================================

# Entorno de ejecución
ASPNETCORE_ENVIRONMENT=Development

# Puerto HTTP (8080 para production, típico en Docker)
ASPNETCORE_HTTP_PORTS=8080

# Clave de firma JWT (MÍNIMO 32 bytes UTF-8)
# ⚠️ EN PRODUCCIÓN: CAMBIAR A UNA CLAVE SEGURA Y MANTENERLA EN SECRETOS
# Generador: openssl rand -base64 32
AUTH_JWT_SIGNING_KEY=tu-super-secreta-llave-de-desarrollo-32-bytes!

# Chain ID permitido para SIWE (Ethereum Sepolia Testnet)
# 11155111 = Sepolia (por defecto)
# 1 = Mainnet Ethereum (futuro)
Auth__AllowedChainId=11155111

# Emisor del JWT (para validación en cliente)
Auth__JwtIssuer=sovereignid-auth

# Audiencia del JWT (clientes permitidos)
Auth__JwtAudience=sovereignid-clients

# TTL del challenge (nonce) en segundos
Auth__ChallengeTtlSeconds=600

# TTL del JWT de sesión en horas
Auth__JwtTtlHours=24

# ============================================================================
# PostgreSQL Configuration
# ============================================================================

# Base de datos (creada automáticamente por el entrypoint de Postgres)
POSTGRES_DB=sovereignid

# Usuario y contraseña de desarrollo (NO usar en producción)
POSTGRES_USER=sovereignid
POSTGRES_PASSWORD=sovereignid_dev

# Puerto expuesto al host
POSTGRES_PORT=5432

# Plantilla de connection string para futuros microservicios (.NET):
# Host=localhost;Port=5432;Database=sovereignid;Username=sovereignid;Password=sovereignid_dev
# Desde contenedores en sovereign-net: Host=postgres;Port=5432;Database=sovereignid;Username=sovereignid;Password=sovereignid_dev
# Si tienes Postgres local en 5432, usa otro puerto en POSTGRES_PORT o apunta al contenedor vía red Docker.
#
# Seed de desarrollo (datos demo holder/verifier):
#   docker compose up -d postgres
#   .\scripts\seed-dev.ps1

# ============================================================================
# Auth API — Persistencia (opcional)
# ============================================================================

# InMemory (default) | Postgres
Persistence__Provider=InMemory

# Requerido cuando Persistence__Provider=Postgres
# ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=sovereignid;Username=sovereignid;Password=sovereignid_dev

# ============================================================================
# Academy API - Invitaciones de institucion
# ============================================================================

# URL del formulario frontend que recibe ?token=...
Academy__InvitationBaseUrl=http://localhost:4200/institution-invitations/accept

# Horas de vigencia del link de invitacion
Academy__InvitationTtlHours=72

# ============================================================================
# Issuer API - Emision de credenciales
# ============================================================================

# Chain ID usado por defecto al vincular titulos emitidos (Sepolia)
Issuer__DefaultChainId=11155111

# ============================================================================
# Issuer API — Persistencia (Postgres en Docker)
# ============================================================================

# Obligatorio para issuer-api (lectura holder + emision)
# ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=sovereignid;Username=sovereignid;Password=sovereignid_dev
# Persistence__Provider=Postgres

# ============================================================================
# Verifier API — Persistencia (Postgres)
# ============================================================================

# Obligatorio para verifier-api (lectura de credentials + verification_logs)
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=sovereignid;Username=sovereignid;Password=sovereignid_dev

# ============================================================================
# Frontend Configuration
# ============================================================================

# Entorno Node.js
NODE_ENV=production

# URL base del API (usado en build-time o runtime)
API_BASE_URL=http://auth-api:8080

# ============================================================================
# Docker Compose Settings
# ============================================================================

# Nombre del proyecto (prefijo de contenedores)
COMPOSE_PROJECT_NAME=sovereignid

# Versión de Compose
COMPOSE_VERSION=3.8

# ============================================================================
# Resources & Logging (Opcional)
# ============================================================================

# Límites de recursos (CPU, Memoria)
# Auth API: 0.5 CPU, 512M RAM
# Web: 0.5 CPU, 256M RAM
# (Ajustar según tu máquina)

# Nivel de log de Nginx (debug, info, warn, error)
NGINX_LOG_LEVEL=warn

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
#
# 1. DESARROLLO LOCAL:
#    - Las contraseñas/claves aquí son solo para desarrollo
#    - No comitear .env con secretos reales al repositorio
#
# 2. PRODUCCIÓN:
#    - Usar Docker secrets o gestores de secretos (Vault, AWS Secrets Manager, etc.)
#    - Cambiar AUTH_JWT_SIGNING_KEY a una clave segura
#    - Cambiar ASPNETCORE_ENVIRONMENT a Production
#    - Configurar CORS correctamente con dominios reales
#
# 3. GENERADOR DE CLAVES SEGURAS:
#    openssl rand -base64 32  # Para JWT_SIGNING_KEY
#
# 4. VALIDACIÓN:
#    docker-compose config  # Validar sintaxis
#
