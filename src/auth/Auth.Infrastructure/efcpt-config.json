{
  "$schema": "https://raw.githubusercontent.com/ErikEJ/EFCorePowerTools/master/samples/efcpt-config.schema.json",
  "code-generation": {
    "enable-on-configuring": false,
    "generate-mermaid-diagram": true,
    "merge-dacpacs": false,
    "refresh-object-lists": true,
    "remove-defaultsql-from-bool-properties": true,
    "soft-delete-obsolete-files": true,
    "t4-template-path": null,
    "type": "all",
    "use-alternate-stored-procedure-resultset-discovery": false,
    "use-stored-procedure-resultset-fallback": true,
    "use-data-annotations": false,
    "use-database-names": false,
    "use-database-names-for-routines": true,
    "use-decimal-data-annotation-for-sproc-results": true,
    "use-inflector": true,
    "use-internal-access-modifiers-for-sprocs-and-functions": false,
    "use-legacy-inflector": false,
    "use-many-to-many-entity": false,
    "use-nullable-reference-types": true,
    "use-prefix-navigation-naming": false,
    "use-typed-tvp-parameters": true,
    "use-t4": false,
    "use-t4-split": false
  },
  "file-layout": {
    "output-dbcontext-path": null,
    "output-path": "Persistence/Generated"
  },
  "names": {
    "dbcontext-name": "SovereignIdDbContext",
    "dbcontext-namespace": null,
    "model-namespace": "Persistence.Generated.Entities",
    "root-namespace": "Auth.Infrastructure"
  },
  "tables": [
    {
      "name": "public.audit_logs"
    },
    {
      "name": "public.auth_challenges"
    },
    {
      "name": "public.careers"
    },
    {
      "name": "public.credential_types"
    },
    {
      "name": "public.credentials"
    },
    {
      "name": "public.institution_metrics_daily"
    },
    {
      "name": "public.institution_users"
    },
    {
      "name": "public.institutions"
    },
    {
      "name": "public.student_wallets"
    },
    {
      "name": "public.students"
    },
    {
      "name": "public.users"
    },
    {
      "name": "public.verification_logs"
    }
  ],
  "type-mappings": {
    "use-DateOnly-TimeOnly": true,
    "use-HierarchyId": false,
    "use-NodaTime": false,
    "use-spatial": false
  }
}