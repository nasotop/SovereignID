{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Persistence": {
    "Provider": "InMemory"
  },
  "Issuer": {
    "DefaultChainId": 11155111,
